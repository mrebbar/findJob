# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Admin ID (sizning Telegram ID)
ADMIN_ID=123456789

# User Bot
API_ID=123456
API_HASH=your_api_hash_here
SESSION=your_session_string

# Output Channel
OUTPUT_CHANNEL=@your_channel_name

# Webhook o'rnatish (optional)
# Polling rejimi uchun o'chirib qo'ying yoki USE_WEBHOOK=false
USE_WEBHOOK=false

# Webhook konfiguratsiyasi (faqat webhook rejimida)
PORT=8000
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=your-secret-key-here
